{
  "name": "@flowcord/core",
  "version": "0.1.0-alpha.1",
  "description": "Lifecycle-driven interactive menu framework for Discord.js",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "ARCHITECTURE.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "build:watch": "tsc -p tsconfig.build.json --watch",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build",
    "release:alpha": "npm version prerelease --preid=alpha && git push --follow-tags",
    "release:patch": "npm version patch && git push --follow-tags",
    "release:minor": "npm version minor && git push --follow-tags",
    "flow:setup": "node scripts/setup-env.js",
    "flow": "tsx --env-file=.env examples/bot.ts"
  },
  "publishConfig": {
    "access": "public",
    "tag": "next"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flowcord-dev/flowcord-core.git"
  },
  "homepage": "https://github.com/flowcord-dev/flowcord-core#readme",
  "bugs": {
    "url": "https://github.com/flowcord-dev/flowcord-core/issues"
  },
  "author": "Nicholas Bely",
  "keywords": [
    "discord",
    "discord.js",
    "menu",
    "interaction",
    "framework",
    "flowcord"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false,
  "peerDependencies": {
    "discord.js": "^14.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "discord.js": "^14.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0"
  }
}
